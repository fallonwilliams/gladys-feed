"""Generic memorandum of understanding template generator.

This file is intentionally generic and avoids naming any real companies,
programs, customer entities, contact details, or non-public agreement terms.
"""

from reportlab.lib.pagesizes import LETTER
from reportlab.lib.units import inch
from reportlab.pdfgen import canvas


file_path = "/mnt/data/mou_template.pdf"

c = canvas.Canvas(file_path, pagesize=LETTER)
width, height = LETTER

title = "MEMORANDUM OF UNDERSTANDING (MoU)"
subtitle = "Example deployment template for a public telemetry pilot"
country_placeholder = "<COUNTRY NAME>"
date_placeholder = "<DD/MM/YYYY>"

margin = 0.75 * inch
line_height = 14

y = height - margin
c.setFont("Helvetica-Bold", 14)
c.drawCentredString(width / 2, y, title)

y -= line_height * 2
c.setFont("Helvetica", 11)
c.drawCentredString(width / 2, y, subtitle)
y -= line_height * 2

c.setFont("Helvetica-Bold", 11)
c.drawString(margin, y, "Parties")
y -= line_height

c.setFont("Helvetica", 10)
parties = [
    ("Public-sector energy counterpart", country_placeholder),
    ("Telemetry platform operator", "<JURISDICTION>"),
    ("Connectivity provider", "<JURISDICTION>"),
    ("Cloud services provider", "<JURISDICTION>"),
    ("Hardware support partner", "<JURISDICTION>"),
]
for org, addr in parties:
    c.drawString(margin, y, f"- {org} | {addr}")
    y -= line_height

y -= line_height

sections = [
    (
        "1. Purpose",
        "To evaluate deployment of a telemetry pilot that improves visibility into grid conditions and operational response.",
    ),
    (
        "2. Commitments",
        "Each party will define its responsibilities in a public annex or a separately executed agreement.",
    ),
    (
        "3. Data Handling",
        "Example feed data is limited to operational telemetry. No personal data or secrets are included in this template.",
    ),
    (
        "4. Term and Exit",
        "This template is illustrative only and requires review before use in any real deployment.",
    ),
    (
        "5. Financial Terms",
        "No financial commitments are implied by this example template.",
    ),
]

for header, text in sections:
    c.setFont("Helvetica-Bold", 11)
    c.drawString(margin, y, header)
    y -= line_height
    c.setFont("Helvetica", 10)
    c.drawString(margin + 12, y, text)
    y -= line_height * 1.5

c.setFont("Helvetica-Bold", 11)
c.drawString(margin, y, "Signed at ______________________ on " + date_placeholder + ":")
y -= line_height * 2

signatories = [
    "For the public-sector counterpart",
    "For the telemetry platform operator",
    "For the connectivity provider",
    "For the cloud services provider",
    "For the hardware support partner",
]
c.setFont("Helvetica", 10)
for line in signatories:
    c.drawString(margin, y, line + ": ______________________________")
    y -= line_height * 1.5

c.save()

file_path
